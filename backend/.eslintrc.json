{
  "env": {
    "node": true,
    "es2022": true
  },
  "extends": ["airbnb-base"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-console": ["error", { "allow": ["warn", "error"] }],
    "import/extensions": ["error", "ignorePackages"]
  }
}
